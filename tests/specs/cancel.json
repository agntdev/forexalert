[
  {
    "name": "/cancel with no args shows usage",
    "steps": [
      {
        "send": { "text": "/cancel" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Usage: /cancel [alert ID]\n\nFind your alert IDs with /list."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "/cancel with unknown ID shows error",
    "steps": [
      {
        "send": { "text": "/cancel badid123" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Alert not found — check the ID and try again."
            }
          }
        ]
      }
    ]
  }
]
